                    Label:
                        text: "[N]  Тёмная тема"
                        font_size: dp(14)
                        color: get_color_from_hex("#FFFFFF")
                        halign: "left"
                        text_size: self.size
                    Switch:
                        size_hint_x: None
                        width: dp(60)
                        active: root.dark_mode
                        on_active: root.toggle_dark(self.active)
                BoxLayout:
                    size_hint_y: None
