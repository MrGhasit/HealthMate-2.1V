<ReminderScreen>:
    BoxLayout:
        orientation: "vertical"
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: [dp(14), dp(10)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#080E16")
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint: None, None
                size: dp(44), dp(44)
                pos_hint: {"center_y": 0.5}
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: app.root.current = "app_screen"
                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#1E2E3E")
                    Ellipse:
                        size: dp(44), dp(44)
                        pos: self.pos
                Image:
                    source: "images/back.png"
                    size_hint: None, None
                    size: dp(30), dp(30)
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    allow_stretch: True
                    keep_ratio: True
            Label:
                text: "Режим дня"
                font_size: dp(20)
