                        text_size: self.size
                    Switch:
                        size_hint_x: None
                        width: dp(60)
                        active: root.notif_enabled
                        on_active: root.toggle_notif(self.active)
                BoxLayout:
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(16), dp(10)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#1A2535")
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(14)]
                    Label:
