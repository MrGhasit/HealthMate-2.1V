            Button:
                size_hint: None, None
                size: dp(44), dp(44)
                pos_hint: {"center_y": 0.5}
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: app.root.current = "app_screen"
                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#1E2E3E")
                    Ellipse:
                        size: dp(44), dp(44)
                        pos: self.pos
                Image:
                    source: "images/back.png"
                    size_hint: None, None
                    size: dp(30), dp(30)
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    allow_stretch: True
                    keep_ratio: True
            Label:
                text: "Погода Казахстана"
                font_size: dp(18)
                bold: True
                color: get_color_from_hex("#FFFFFF")
                halign: "left"
                text_size: self.size
                valign: "middle"
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: [dp(10), dp(8)]
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#080E16")
                Rectangle:
                    size: self.size
                    pos: self.pos
            ScrollView:
                do_scroll_x: True
                do_scroll_y: False
                bar_width: 0
                BoxLayout:
                    id: city_bar
                    orientation: "horizontal"
                    size_hint_x: None
                    width: self.minimum_width
                    spacing: dp(8)
                    padding: [dp(4), 0]
        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(14), dp(12)]
                spacing: dp(12)
                Label:
                    text: "Загрузка..."
                    font_size: dp(15)
                    color: get_color_from_hex("#6BCB77")
                    halign: "center"
                    size_hint_y: None
                    height: dp(44) if root.loading else dp(0)
                    opacity: 1 if root.loading else 0
                Label:
                    text: root.error_text
                    font_size: dp(14)
                    color: get_color_from_hex("#E74C3C")
                    halign: "center"
                    size_hint_y: None
                    height: dp(44) if root.error_text else dp(0)
                    opacity: 1 if root.error_text else 0
                BoxLayout:
                    id: weather_cards
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(12)

