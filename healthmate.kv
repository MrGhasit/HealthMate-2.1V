<SettingsScreen>:
    BoxLayout:
        orientation: "vertical"
        BoxLayout:
            size_hint_y: None
            height: dp(60)
            padding: [dp(14), dp(10)]
            spacing: dp(10)
            canvas.before:
                Color:
                    rgba: get_color_from_hex("#080E16")
                Rectangle:
                    size: self.size
                    pos: self.pos
            Button:
                size_hint: None, None
                size: dp(44), dp(44)
                pos_hint: {"center_y": 0.5}
                background_normal: ""
                background_color: 0, 0, 0, 0
                on_release: root.go_back()
                canvas.before:
                    Color:
                        rgba: get_color_from_hex("#1E2E3E")
                    Ellipse:
                        size: dp(44), dp(44)
                        pos: self.pos
                Image:
                    source: "images/back.png"
                    size_hint: None, None
                    size: dp(30), dp(30)
                    pos_hint: {"center_x": 0.5, "center_y": 0.5}
                    allow_stretch: True
                    keep_ratio: True
            Label:
                text: "Профиль и настройки"
                font_size: dp(18)
                bold: True
                color: get_color_from_hex("#FFFFFF")
                halign: "left"
                text_size: self.size
                valign: "middle"
        ScrollView:
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: [dp(16), dp(14)]
                spacing: dp(10)
                BoxLayout:
                    size_hint_y: None
                    height: dp(90)
                    spacing: dp(14)
                    padding: dp(16)
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#1A2535")
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(18)]
                    BoxLayout:
                        size_hint: None, None
                        size: dp(54), dp(54)
                        pos_hint: {"center_y": 0.5}
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#6BCB77")
                            Ellipse:
                                size: dp(54), dp(54)
                                pos: self.pos
                        Label:
                            text: "Я"
                            font_size: dp(22)
                            bold: True
                            color: get_color_from_hex("#FFFFFF")
                            halign: "center"
                            valign: "middle"
                    BoxLayout:
                        orientation: "vertical"
                        Label:
                            text: "Гость"
                            font_size: dp(18)
                            bold: True
                            color: get_color_from_hex("#FFFFFF")
                            halign: "left"
                            text_size: self.size
                            valign: "bottom"
                        Label:
                            text: "Гостевой аккаунт" if root.is_guest else "Зарегистрирован"
                            font_size: dp(13)
                            color: get_color_from_hex("#6BCB77")
                            halign: "left"
                            text_size: self.size
                            valign: "top"
                BoxLayout:
                    size_hint_y: None
                    height: dp(50) if root.is_guest else dp(0)
                    spacing: dp(10)
                    opacity: 1 if root.is_guest else 0
                    Button:
                        text: "Войти"
                        background_normal: ""
                        background_color: 0, 0, 0, 0
                        color: get_color_from_hex("#6BCB77")
                        font_size: dp(15)
                        bold: True
                        on_release: app.root.current = "login"
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#6BCB77")
                            Line:
                                rounded_rectangle: [self.x, self.y, self.width, self.height, dp(25)]
                                width: dp(1.5)
                    Button:
                        text: "Регистрация"
                        background_normal: ""
                        background_color: get_color_from_hex("#6BCB77")
                        color: get_color_from_hex("#FFFFFF")
                        font_size: dp(15)
                        bold: True
                        on_release: app.root.current = "register"
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#6BCB77")
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(25)]
                Label:
                    text: "БЕЗОПАСНОСТЬ"
                    font_size: dp(11)
                    bold: True
                    color: get_color_from_hex("#4A6A8A")
                    halign: "left"
                    text_size: self.size
                    size_hint_y: None
                    height: dp(22)
                BoxLayout:
                    size_hint_y: None
                    height: dp(52)
                    padding: [dp(16), dp(10)]
                    canvas.before:
                        Color:
                            rgba: get_color_from_hex("#1A2535")
                        RoundedRectangle:
                            size: self.size
                            pos: self.pos
                            radius: [dp(14)]
                    Label:
                        text: "[*]  Touch ID / PIN-код"
                        font_size: dp(14)
                        color: get_color_from_hex("#FFFFFF")
                        halign: "left"
                        text_size: self.size
                    Button:
                        size_hint_x: None
                        width: dp(74)
                        text: "Задать"
                        font_size: dp(12)
                        bold: True
                        background_normal: ""
                        background_color: 0,0,0,0
                        color: get_color_from_hex("#6BCB77")
                        on_release: root.set_pin()
                        canvas.before:
                            Color:
                                rgba: get_color_from_hex("#1E3A2A")
                            RoundedRectangle:
                                size: self.size
                                pos: self.pos
                                radius: [dp(12)]
                Label:
                    text: "ОСНОВНОЕ"
                    font_size: dp(11)
                    bold: True
                    color: get_color_from_hex("#4A6A8A")
                    halign: "left"
                    text_size: self.size
                    size_hint_y: None
                    height: dp(22)
                Button:
