                    size_hint_y: None
                    height: dp(22)
                Button:
                    text: "[+]  Пригласить друзей"
                    size_hint_y: None
                    height: dp(52)
                    background_normal: ""
                    background_color: 0,0,0,0
                    color: get_color_from_hex("#FFFFFF")
                    font_size: dp(14)
                    halign: "left"
                    on_release: root.invite_friends()
                    canvas.before:
